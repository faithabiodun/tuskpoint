# TuskPoint configuration — copy to .env and fill in. NEVER commit your real .env.

# MemWal (semantic layer)
# Ed25519 delegate private key, hex-encoded.
MEMWAL_PRIVATE_KEY=your_ed25519_delegate_key_hex
# Walrus Memory account object ID on Sui.
MEMWAL_ACCOUNT_ID=your_walrus_memory_account_object_id
# MemWal environment preset: prod | staging | dev | local. Must match where
# your credentials were issued (default: prod).
MEMWAL_ENV=prod
# OPTIONAL: explicit relayer URL from your MemWal dashboard. If set, this takes
# precedence over MEMWAL_ENV (the dashboard is the source of truth).
# MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
# OPTIONAL: namespace to isolate this app's memories (default: tuskpoint).
MEMWAL_NAMESPACE=tuskpoint

# Walrus blob store (exact layer) — DEFAULT: TESTNET
# Testnet has a public, free publisher, so writes need no wallet or tokens.
# These are also the built-in defaults, so you can leave them unset.
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
#
# To use MAINNET instead (durable, paid storage), set both to mainnet:
#   WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
# Mainnet writes are NOT free and there is no public, unauthenticated
# publisher: storing a blob costs SUI (gas) + WAL (storage). Options:
#   1. A community publisher (may rate-limit / require an allowlist), e.g.:
#      WALRUS_PUBLISHER_URL=https://walrus-mainnet-publisher-1.staketab.org:443
#   2. Run your own publisher with a funded Sui key (recommended for prod):
#        walrus publisher --sui-wallet <path> ...
#   3. Use the mainnet upload relay with a funded key:
#        https://upload-relay.mainnet.walrus.space
# Reads work without any of this; only writes (checkpoint_save / fork) need it.

# Demo agent LLM
# The demo agent is provider-agnostic. Set LLM_PROVIDER to "anthropic" or
# "deepseek" and supply the matching key. DeepSeek uses an OpenAI-compatible
# API, so only the key is needed here.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
# DeepSeek model ID (OpenAI-compatible API). Default: deepseek-chat.
DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Live dashboard service (api_service/, deployed separately)
# The FastAPI service in api_service/ hosts the real WalrusSaver so the website's
# /dashboard can call the engine live. Run it on a free Python host (Render /
# Hugging Face Spaces / Koyeb). For the demo it points at Walrus TESTNET so the
# save/fork buttons make FREE writes — visitors can't drain mainnet funds.
#
# Set these in the FastAPI host's env (NOT in the browser):
#   WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
#   WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
#   MEMWAL_PRIVATE_KEY / MEMWAL_ACCOUNT_ID (as above)
# Shared secret the Next.js proxy sends as `x-tuskpoint-token`. Gates the
# write endpoints (save/fork). Pick any long random string.
TUSKPOINT_API_TOKEN=choose_a_long_random_string
# The thread the dashboard opens by default.
TUSKPOINT_DEMO_THREAD=run-43312
# Browser origin allowed to call the service directly (the Vercel URL). The
# same-origin Next proxy means this is rarely hit by the browser.
ALLOWED_ORIGIN=https://tuskpoint.vercel.app
# Where the saver caches per-thread manifest blob IDs on the host.
WALRUS_THREADS_CACHE=.walrus_threads.json

# Next.js (Vercel) server-side env — NOT NEXT_PUBLIC_
# Public URL of the deployed FastAPI service above, and the same token.
TUSKPOINT_API_URL=https://your-tuskpoint-engine.onrender.com
# TUSKPOINT_API_TOKEN=choose_a_long_random_string   (same value as the service)
# OPTIONAL public override of the default demo thread shown in the dashboard.
# NEXT_PUBLIC_DEMO_THREAD=run-43312
